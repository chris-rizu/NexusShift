# Admin Dashboard — copy to .env and fill in YOUR Supabase values.
# PUBLIC values (safe in a frontend; reads are gated by Auth + RLS).
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Only needed to run the optional setup-database.js / server.js admin scripts.
# SECRET — do not commit, do not ship in the agent.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
