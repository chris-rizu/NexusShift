# Worker Agent — copy to .env and fill in YOUR Supabase values.
# Injected into the agent at build time (electron-vite MAIN_VITE_ prefix).
# PUBLIC values only — the agent must NEVER contain the service-role key.

MAIN_VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
MAIN_VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Agent settings
SCREENSHOT_INTERVAL_MINUTES=5
IDLE_THRESHOLD_SECONDS=600
AUTO_START=true
