# Docker Environment Configuration
# Copy this file to .env and fill in YOUR OWN Supabase project values.

# Supabase Configuration (Supabase project -> Settings -> API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# SECRET — used only for one-time admin/setup scripts. NEVER ship this in the agent.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Worker Agent Settings
SCREENSHOT_INTERVAL_MINUTES=5
IDLE_THRESHOLD_SECONDS=600
AUTO_START=true
MAX_SCREENSHOT_QUEUE_SIZE=100
UPLOAD_RETRY_ATTEMPTS=3

# PostgreSQL (for local development, if not using Supabase)
POSTGRES_USER=nexusshift
POSTGRES_PASSWORD=change_me
POSTGRES_DB=nexusshift
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis (for caching and queues)
REDIS_HOST=redis
REDIS_PORT=6379
